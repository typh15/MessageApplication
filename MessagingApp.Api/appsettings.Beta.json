{
  "BetaServer": {
    "UseForwardedHeaders": true,
    "UseHttpsRedirection": false
  },
  "ConnectionStrings": {
    "MessagingAppData": "Data Source=App_Data/messagingapp.beta.sqlite"
  },
  "Persistence": {
    "Provider": "Sqlite",
    "InitializeDatabaseOnStartup": true,
    "FailStartupOnInitializationError": true
  },
  "RepositoryStorage": {
    "ActiveUsers": "Sqlite",
    "MessageBoards": "Sqlite",
    "UserAccounts": "Sqlite",
    "Images": "Sqlite",
    "PushNotifications": "Sqlite",
    "ConversationSummaries": "Sqlite"
  },
  "ImageStorage": {
    "ClearStoredImagesOnStartup": false
  },
  "Chatbot": {
    "Enabled": true,
    "BaseUrl": "http://127.0.0.1:8000",
    "BotUniqueId": "chatbot-system-user",
    "BotUserName": "Chatbot",
    "PublicImageBaseUrl": "",
    "RecentMessageCount": 10,
    "SummarizeEveryMessageCount": 20,
    "SummaryMaxWords": 300,
    "RequestTimeoutSeconds": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
